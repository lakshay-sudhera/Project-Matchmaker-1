# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/project-matchmaker

# NextAuth configuration
# Generate a secure key using: npx auth secret
AUTH_SECRET=your_nextauth_auth_secret

# GitHub OAuth Credentials
AUTH_GITHUB_ID=your_github_oauth_app_client_id
AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret

# Cloudinary Credentials (For image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Gemini API Key (For AI matchmaking recommendation engine)
GEMINI_API_KEY=your_google_gemini_api_key
