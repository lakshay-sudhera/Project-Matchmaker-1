# MongoDB connection string
MONGODB_URI=your_mongo_db_uri

# NextAuth configuration
# Generate a secure key using: npx auth secret
AUTH_SECRET=your_nextauth_auth_secret

# GitHub OAuth Credentials
AUTH_GITHUB_ID=your_github_oauth_app_client_id
AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret
GITHUB_PAT=your_github_personal_access_token

# Cloudinary Credentials (For image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

#AI API Key (For AI matchmaking recommendation engine)
GEMINI_API_KEY=your_google_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Pusher credentials for real-time chat and typing indicators
PUSHER_APP_ID=your_pusher_app_id
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_CLUSTER=your_pusher_cluster
